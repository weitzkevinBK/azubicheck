rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? profile().data.role
        : null;
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isManagement() {
      return role() == 'management' || isAdmin();
    }

    function isPureManagement() {
      return role() == 'management';
    }

    function isTeacher() {
      return role() == 'teacher' || isManagement();
    }

    function assignedToCourse(courseId) {
      return isManagement()
        || (isTeacher() && courseId in profile().data.assignedCourseIds);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId && (
        (
          request.resource.data.role == 'student'
          && request.resource.data.courseId is string
          && request.resource.data.assignedCourseIds == []
        )
        || (
          request.resource.data.role == 'teacher'
          && request.resource.data.courseId == ''
          && request.resource.data.assignedCourseIds == []
          && request.resource.data.teacherInviteCodeHash == get(/databases/$(database)/documents/settings/registration).data.teacherCodeHash
        )
        || (
          request.resource.data.role == 'management'
          && request.resource.data.courseId == ''
          && request.resource.data.assignedCourseIds == []
          && request.resource.data.managementInviteCodeHash == get(/databases/$(database)/documents/settings/registration).data.managementCodeHash
        )
      );
      allow update: if signedIn() && (
        isAdmin()
        || (
          isPureManagement()
          && resource.data.role != 'admin'
          && request.resource.data.role in ['student', 'teacher', 'management']
        )
        || (
          request.auth.uid == userId
          && request.resource.data.role == resource.data.role
          && request.resource.data.assignedCourseIds == resource.data.assignedCourseIds
        )
      );
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if signedIn();
      allow create, update, delete: if isManagement();
    }

    match /blocks/{blockId} {
      allow read: if signedIn();
      allow create: if signedIn() && assignedToCourse(request.resource.data.courseId);
      allow update, delete: if signedIn() && assignedToCourse(resource.data.courseId);
    }

    match /theoryAttendances/{attendanceId} {
      allow read: if signedIn();
      allow create: if signedIn() && (
        request.auth.uid == request.resource.data.studentId
        || assignedToCourse(request.resource.data.courseId)
      );
      allow update: if signedIn() && (
        request.auth.uid == resource.data.studentId
        || assignedToCourse(resource.data.courseId)
      );
      allow delete: if isManagement();
    }

    match /practiceAttendances/{attendanceId} {
      allow read: if signedIn();
      allow create: if signedIn() && assignedToCourse(request.resource.data.courseId);
      allow update, delete: if signedIn() && assignedToCourse(resource.data.courseId);
    }

    match /dayOverrides/{overrideId} {
      allow read: if signedIn();
      allow create: if signedIn() && assignedToCourse(request.resource.data.courseId);
      allow update, delete: if signedIn() && assignedToCourse(resource.data.courseId);
    }
  }
}
