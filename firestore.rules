rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function myRole() {
      return signedIn() && userDoc(request.auth.uid).data.role;
    }

    function isAdmin() {
      return myRole() == 'admin';
    }

    function isManagement() {
      return myRole() == 'management' || isAdmin();
    }

    function isTeacher() {
      return myRole() == 'teacher' || isManagement();
    }

    function assignedToCourse(courseId) {
      return isManagement()
        || (isTeacher() && courseId in userDoc(request.auth.uid).data.assignedCourseIds);
    }

    match /users/{userId} {
      allow read: if signedIn() && (
        request.auth.uid == userId
        || isManagement()
        || (isTeacher() && resource.data.role == 'student' && assignedToCourse(resource.data.courseId))
      );
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (
        request.auth.uid == userId && !('role' in request.resource.data.diff(resource.data).changedKeys())
        || isManagement()
      );
      allow delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if signedIn();
      allow write: if isManagement();
    }

    match /blocks/{blockId} {
      allow read: if signedIn() && assignedToCourse(resource.data.courseId);
      allow create: if signedIn() && assignedToCourse(request.resource.data.courseId);
      allow update, delete: if signedIn() && assignedToCourse(resource.data.courseId);
    }

    match /theoryAttendances/{attendanceId} {
      allow read: if signedIn() && (
        request.auth.uid == resource.data.studentId
        || assignedToCourse(resource.data.courseId)
      );
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.studentId;
      allow update: if signedIn() && (
        request.auth.uid == resource.data.studentId
        || assignedToCourse(resource.data.courseId)
      );
      allow delete: if isManagement();
    }

    match /practiceAttendances/{attendanceId} {
      allow read: if signedIn() && (
        request.auth.uid == resource.data.studentId
        || assignedToCourse(resource.data.courseId)
      );
      allow write: if signedIn() && assignedToCourse(request.resource.data.courseId);
    }

    match /dayOverrides/{overrideId} {
      allow read: if signedIn() && assignedToCourse(resource.data.courseId);
      allow write: if signedIn() && assignedToCourse(request.resource.data.courseId);
    }
  }
}
